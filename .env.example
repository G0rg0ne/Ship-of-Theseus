# =============================================================================
# Ship of Theseus — Production .env
# Copy this file to .env and set real values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Security (REQUIRED)
# -----------------------------------------------------------------------------
# JWT signing; generate with: openssl rand -hex 32
SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# CORS & frontend
# -----------------------------------------------------------------------------
# Comma-separated origins the browser may call (your frontend URL(s))
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# Public API URL (baked into frontend at build time; must be browser-accessible)
NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# Frontend URL for email verification links
FRONTEND_URL=https://yourdomain.com

# -----------------------------------------------------------------------------
# PostgreSQL (used by docker-compose.prod.yml; backend DATABASE_URL is built from these)
# -----------------------------------------------------------------------------
POSTGRES_USER=ship_user
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=shipoftheseus

# -----------------------------------------------------------------------------
# Neo4j
# -----------------------------------------------------------------------------
# In Docker prod, backend connects to the neo4j service:
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
NEO4J_DATABASE=neo4j
# Optional: path inside backend container to Neo4j data (for admin store-size metrics)
# NEO4J_DATA_PATH=/data/neo4j

# -----------------------------------------------------------------------------
# Redis (Docker prod: backend uses redis service; override if needed)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Database URL (optional here when using docker-compose.prod.yml — it overrides
# DATABASE_URL from POSTGRES_* so backend talks to postgres service)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://ship_user:YOUR_PASSWORD@postgres:5432/shipoftheseus

# -----------------------------------------------------------------------------
# OpenAI (REQUIRED for extraction & GraphRAG)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-REPLACE_WITH_YOUR_OPENAI_KEY
ENTITY_EXTRACTION_MODEL=gpt-4o-mini
ENTITY_EXTRACTION_BATCH_SIZE=10
ENTITY_EXTRACTION_CONCURRENCY=20
RELATIONSHIP_EXTRACTION_BATCH_SIZE=10
RELATIONSHIP_EXTRACTION_CONCURRENCY=20
AUTO_EXTRACT_RELATIONSHIPS=true
LLM_RETRY_MAX_ATTEMPTS=3
LLM_RETRY_BASE_DELAY_MS=500
LLM_RETRY_MAX_DELAY_MS=5000

# -----------------------------------------------------------------------------
# GraphRAG — summarization & embedding
# -----------------------------------------------------------------------------
EMBEDDING_MODEL=text-embedding-3-small
COMMUNITY_SUMMARIZATION_MODEL=gpt-4o-mini

# -----------------------------------------------------------------------------
# GraphRAG — query pipeline
# -----------------------------------------------------------------------------
QUERY_ROUTER_MODEL=gpt-4o-mini
QUERY_SYNTHESIS_MODEL=gpt-4o-mini
QUERY_ENTITY_TOP_K=15
QUERY_COMMUNITY_TOP_K=10
QUERY_SIMILARITY_THRESHOLD=0.7
QUERY_MAX_SUMMARY_CHARS=800
QUERY_ANSWER_CACHE_TTL=3600
CHAT_HISTORY_TTL_SECONDS=86400
CHAT_HISTORY_WINDOW=6

# -----------------------------------------------------------------------------
# Document chunking
# -----------------------------------------------------------------------------
DOCUMENT_CHUNK_SIZE=800
DOCUMENT_CHUNK_OVERLAP=150

# -----------------------------------------------------------------------------
# Admin / infra (optional)
# -----------------------------------------------------------------------------
DISK_MOUNT_PATHS=/,/data
DISK_WARN_PERCENT=80
DISK_CRIT_PERCENT=90

# -----------------------------------------------------------------------------
# SMTP (email verification)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_FROM=noreply@yourdomain.com

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
DEBUG=false